# =============================================================================
# ProxyClaw Stack - 环境变量配置模板
# =============================================================================
# 首次使用会自动生成统一密钥，也可在下方手动配置
# =============================================================================

# =============================================================================
# 一、PostgreSQL 配置
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__RANDOM_PASSWORD__
POSTGRES_DB=proxyclaw
POSTGRES_PORT=5432

PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=${POSTGRES_PASSWORD}
PG_DATABASE=proxyclaw
PG_SSL_MODE=disable

# =============================================================================
# 二、Redis 配置
# =============================================================================
REDIS_PORT=26379
REDIS_PASSWORD=

# =============================================================================
# 三、Elasticsearch 配置
# =============================================================================
ELASTICSEARCH_PORT=29200
ELASTICSEARCH_TRANSPORT_PORT=29300
ELASTICSEARCH_PASSWORD=__RANDOM_PASSWORD__
ELASTICSEARCH_ENABLED=false

# =============================================================================
# 四、Kibana 配置
# =============================================================================
KIBANA_PORT=25601

# =============================================================================
# 五、Qdrant 配置
# =============================================================================
QDRANT_PORT=6333
MEM0_QDRANT_HOST=proxyclaw-qdrant
MEM0_QDRANT_PORT=6333
MEM0_QDRANT_API_KEY=__RANDOM_PASSWORD__

# =============================================================================
# 六、Neo4j 配置
# =============================================================================
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_PASSWORD=__RANDOM_PASSWORD__
NEO4J_USERNAME=neo4j

# =============================================================================
# 七、Ollama 配置
# =============================================================================
OLLAMA_PORT=21434
OLLAMA_HOST=http://localhost:21434
OLLAMA_DEFAULT_MODEL=bge-m3
OLLAMA_AUTOLOAD_MODEL=true
OLLAMA_BASE_URL=http://proxyclaw-ollama:11434

# 额外预拉取的模型列表（逗号分隔，如 "qwen2.5:1.5b,gemma4:e2b"）
OLLAMA_MODELS_TO_LOAD=

# =============================================================================
# 八、Mem0 Server 配置
# =============================================================================
MEM0_ENABLED=true
MEM0_PORT=20061
MEM0_API_URL=http://localhost:20061
MEM0_ADMIN_API_KEY=__RANDOM_PASSWORD__
MEM0_JWT_SECRET=__RANDOM_PASSWORD__
MEM0_AUTH_DISABLED=false

# Mem0 LLM / Embedder Provider（openai 或 ollama，默认 ollama）
LLM_PROVIDER=ollama
EMBEDDER_PROVIDER=ollama

# Mem0 使用的 OpenAI API（provider=openai 时需要填入真实密钥）
MEM0_OPENAI_API_KEY=
MEM0_OPENAI_BASE_URL=http://proxyclaw-ollama:11434/v1
MEM0_OPENAI_MODEL=gemma4:e2b
MEM0_OPENAI_EMBEDDING_MODEL=bge-m3:latest

# Mem0 嵌入维度（Ollama bge-m3 输出 1024 维，OpenAI text-embedding-3-small 输出 1536 维）
MEM0_EMBEDDING_DIMS=1024

# Mem0 数据库配置（使用共享 PostgreSQL）
MEM0_POSTGRES_HOST=proxyclaw-postgresql
MEM0_POSTGRES_PORT=5432
MEM0_POSTGRES_DB=${POSTGRES_DB}
MEM0_POSTGRES_USER=postgres
MEM0_POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
MEM0_APP_DB_NAME=proxyclaw
MEM0_POSTGRES_COLLECTION_NAME=memories
MEM0_TELEMETRY=false

# =============================================================================
# 九、Pi Sandbox（Pi Agent HTTP 网关，见 pi-sandbox/ 与 services/pi-sandbox/）
# =============================================================================
PI_SANDBOX_PORT=20062
PI_SANDBOX_API_URL=http://localhost:20062
# 至少配置一个供应商 Key（容器内 npm 全局 pi 与 Go pi-server 共用）
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
