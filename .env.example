# =============================================================================
# ProxyClaw Stack - 环境变量配置模板
# =============================================================================
# 首次使用会自动生成统一密钥，也可在下方手动配置
# =============================================================================

# =============================================================================
# 一、PostgreSQL 配置
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__RANDOM_PASSWORD__
POSTGRES_DB=proxyclaw
POSTGRES_PORT=5432

PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=${POSTGRES_PASSWORD}
PG_DATABASE=proxyclaw
PG_SSL_MODE=disable

# =============================================================================
# 二、Redis 配置
# =============================================================================
REDIS_PORT=26379
REDIS_PASSWORD=

# =============================================================================
# 三、Elasticsearch 配置
# =============================================================================
ELASTICSEARCH_PORT=29200
ELASTICSEARCH_TRANSPORT_PORT=29300
ELASTICSEARCH_PASSWORD=__RANDOM_PASSWORD__
ELASTICSEARCH_ENABLED=false

# =============================================================================
# 四、Kibana 配置
# =============================================================================
KIBANA_PORT=25601

# =============================================================================
# 五、Qdrant 配置
# =============================================================================
QDRANT_PORT=6333
MEM0_QDRANT_HOST=proxyclaw-qdrant
MEM0_QDRANT_PORT=6333
MEM0_QDRANT_API_KEY=__RANDOM_PASSWORD__
MEM0_NEO4J_URI=bolt://proxyclaw-neo4j:7687

# =============================================================================
# 六、Neo4j 配置
# =============================================================================
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_PASSWORD=__RANDOM_PASSWORD__
NEO4J_USERNAME=neo4j

# =============================================================================
# 七、Ollama 配置（本地免费 LLM / Embedding；Mem0 混合方案下用于向量化）
# =============================================================================
OLLAMA_PORT=21434
OLLAMA_HOST=http://localhost:21434
# 默认嵌入模型 bge-m3（1024 维，中文友好）；容器启动时会自动拉取
OLLAMA_DEFAULT_MODEL=bge-m3
OLLAMA_AUTOLOAD_MODEL=true
# 容器内访问地址（勿改为 localhost，mem0 容器通过此地址连 Ollama）
OLLAMA_BASE_URL=http://proxyclaw-ollama:11434

# 额外预拉取的模型列表（逗号分隔，如 "qwen2.5:1.5b,gemma4:e2b"）
OLLAMA_MODELS_TO_LOAD=

# =============================================================================
# 八、Mem0 Server 配置
# =============================================================================
MEM0_ENABLED=true
MEM0_PORT=20061
MEM0_API_URL=http://localhost:20061
MEM0_ADMIN_API_KEY=__RANDOM_PASSWORD__
MEM0_JWT_SECRET=__RANDOM_PASSWORD__
MEM0_AUTH_DISABLED=false

# --- Mem0 模型方案（LLM_PROVIDER 与 EMBEDDER_PROVIDER 可独立配置）---
#
# [方案 1] 全本地 Ollama（开发推荐，零 API 费用）
#   LLM_PROVIDER=ollama
#   EMBEDDER_PROVIDER=ollama
#   MEM0_EMBEDDING_DIMS=1024
#
# [方案 2] 全云端 OpenAI 兼容 API（LLM + Embedding 均走 API）
#   LLM_PROVIDER=openai
#   EMBEDDER_PROVIDER=openai
#   MEM0_OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#   MEM0_OPENAI_MODEL=glm-4-flash
#   MEM0_OPENAI_EMBEDDING_MODEL=embedding-3   # BigModel: embedding-2 / embedding-3（按量计费，非免费）
#   MEM0_EMBEDDING_DIMS=1024                  # embedding-3 支持 256–2048 自定义维度
#
# [方案 3] 混合（推荐：BigModel LLM + Ollama 免费 Embedding）← 下方默认值
#   LLM_PROVIDER=openai
#   EMBEDDER_PROVIDER=ollama
#   MEM0_OPENAI_MODEL=glm-4-flash
#   MEM0_OPENAI_EMBEDDING_MODEL=bge-m3:latest # 此处为 Ollama 模型名，不是 BigModel 模型
#   MEM0_EMBEDDING_DIMS=1024
#
# 注意：
# - BigModel 不提供免费的 Embedding API；向量化请用 Ollama bge-m3 或充值后用 embedding-2/3
# - MEM0_OPENAI_EMBEDDING_MODEL 会映射到容器 MEM0_DEFAULT_EMBEDDER_MODEL（见 compose/overrides/stack-mem0.yaml）
# - 修改本节 Provider 或模型后需重启: ./start.sh restart mem0

LLM_PROVIDER=openai
EMBEDDER_PROVIDER=ollama

# LLM（仅当 LLM_PROVIDER=openai 时需要；填入智谱 / OpenAI 等兼容 API Key，勿提交到版本库）
MEM0_OPENAI_API_KEY=
# 可选：与 MEM0_OPENAI_API_KEY 保持一致，供部分工具链读取
OPENAI_API_KEY=
MEM0_OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
MEM0_OPENAI_MODEL=glm-4-flash
# EMBEDDER_PROVIDER=ollama 时：Ollama 嵌入模型名（如 bge-m3:latest）
# EMBEDDER_PROVIDER=openai 时：云端嵌入模型名（BigModel 用 embedding-2 或 embedding-3）
MEM0_OPENAI_EMBEDDING_MODEL=bge-m3:latest

# 向量维度须与嵌入模型一致：Ollama bge-m3=1024；OpenAI text-embedding-3-small=1536
MEM0_EMBEDDING_DIMS=1024

# Mem0 数据库配置（使用共享 PostgreSQL）
MEM0_POSTGRES_HOST=proxyclaw-postgresql
MEM0_POSTGRES_PORT=5432
MEM0_POSTGRES_DB=${POSTGRES_DB}
MEM0_POSTGRES_USER=postgres
MEM0_POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
MEM0_APP_DB_NAME=proxyclaw
MEM0_POSTGRES_COLLECTION_NAME=memories
MEM0_TELEMETRY=false

# =============================================================================
# 九、Pi Sandbox（Pi Agent HTTP 网关，见 pi-sandbox/ 与 services/pi-sandbox/）
# =============================================================================
PI_SANDBOX_PORT=20062
PI_SANDBOX_API_URL=http://localhost:20062
# npm 全局 pi 包（默认 @earendil-works/pi-coding-agent@0.78.1，旧包 @mariozechner 已弃用）
PI_PACKAGE=@earendil-works/pi-coding-agent
PI_VERSION=0.78.1
PI_SKIP_VERSION_CHECK=1
# 至少配置一个供应商 Key（容器内 pi 与 Go pi-server 共用；完整列表见 pi-sandbox/scripts/pi-docker.sh）
ANTHROPIC_API_KEY=
ANTHROPIC_OAUTH_TOKEN=
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
KIMI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=
