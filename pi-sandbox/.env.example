# Pi Sandbox Configuration

# Pi Container
PI_IMAGE=pi-sandbox:latest
PI_CONTAINER_NAME=pi-sandbox
PI_WORK_DIR=/workspace

# LLM Provider API Keys (at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=

# Default Model Configuration
PI_DEFAULT_PROVIDER=anthropic
PI_DEFAULT_MODEL=claude-sonnet-4-20250514
PI_THINKING_LEVEL=medium

# Session Configuration
PI_SESSION_DIR=/data/sessions
PI_NO_SESSION=false

# Security Settings
PI_ALLOWED_PATHS=/workspace,/tmp
PI_BLOCKED_PATHS=/etc,/root,/home
PI_ALLOW_NETWORK=true
PI_MAX_FILE_SIZE=10485760

# Resource Limits
PI_MAX_MEMORY=512m
PI_MAX_CPU=1.0
PI_TIMEOUT_SECONDS=300

# Go Client Configuration
GO_CLIENT_PORT=8080
GO_CLIENT_HOST=0.0.0.0

# Logging
LOG_LEVEL=info
LOG_FILE=/var/log/pi-sandbox.log
